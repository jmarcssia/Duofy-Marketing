{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CreationRequest",
  "description": "Entrada do Agente de Cocriacao. Poucos campos sao obrigatorios; o restante e inferido.",
  "type": "object",
  "required": ["brand_slug", "theme"],
  "properties": {
    "brand_slug": { "type": "string", "description": "duofy_solucoes | deathcare | postos_combustiveis" },
    "theme": { "type": "string", "description": "Tema/briefing (obrigatorio)." },
    "channel": { "type": "string", "default": "Instagram" },
    "format": { "type": "string", "default": "Carrossel" },
    "category": { "type": "string", "default": "content_generation" },
    "persona": { "type": ["string", "null"] },
    "objetivo": { "type": ["string", "null"] },
    "cta": { "type": ["string", "null"] },
    "slides": { "type": ["integer", "null"], "minimum": 3, "maximum": 12 },
    "depth": { "type": "string", "enum": ["quick", "deep"], "default": "quick" },
    "tone": { "type": ["string", "null"] },
    "observacoes": { "type": ["string", "null"] },
    "research_output_id": { "type": ["integer", "null"], "description": "ID de uma pesquisa existente a consumir." },
    "previous_content": { "type": ["string", "null"], "description": "Conteudo anterior para reaproveitar." },
    "status": { "type": "string", "default": "draft" },
    "model": { "type": ["string", "null"] },
    "provider": { "type": ["string", "null"] }
  }
}
