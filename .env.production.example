# DUOFY V1 — Produção (VPS). Copie para `.env` e preencha com valores REAIS e fortes.
#   cp .env.production.example .env
# NUNCA versione o .env real. Suba com:
#   docker compose -f docker-compose.prod.yml up -d --build

# ------------------------------------------------------------------
# Domínio / TLS
# ------------------------------------------------------------------
# Domínio apontado (A record) para o IP da VPS => Caddy emite HTTPS automático.
# Para testar por IP antes do domínio, use ":80" (somente HTTP).
DUOFY_SITE_ADDRESS=app.suaempresa.com.br

# ------------------------------------------------------------------
# Banco de dados
# ------------------------------------------------------------------
POSTGRES_DB=duofy_v1
POSTGRES_USER=duofy
# Gere uma senha forte:  openssl rand -base64 24
POSTGRES_PASSWORD=TROQUE_por_senha_forte_do_postgres

# ------------------------------------------------------------------
# Segurança da aplicação
# ------------------------------------------------------------------
# JWT — gere 48+ bytes:  python -c "import secrets; print(secrets.token_urlsafe(48))"
# ATENÇÃO (migração): se você está migrando um banco EXISTENTE, mantenha o MESMO
# JWT_SECRET_KEY do servidor antigo — as chaves de API dos provedores são cifradas
# com ele (Fernet). Trocar o segredo torna as chaves indecifráveis e derruba os agentes.
JWT_SECRET_KEY=TROQUE_por_um_segredo_forte_de_48_bytes
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=720

# Admin inicial (semeado no primeiro boot). Gere uma senha forte:  openssl rand -base64 18
ADMIN_EMAIL=admin@suaempresa.com.br
ADMIN_PASSWORD=TROQUE_por_senha_forte_do_admin
ADMIN_NAME=Admin Duofy

# CORS: por padrão o frontend chama /api na MESMA origem (via Caddy), sem CORS.
# Só preencha se for servir a API em outro domínio (ex.: https://api.suaempresa.com.br).
# BACKEND_CORS_ORIGINS=https://app.suaempresa.com.br

# ------------------------------------------------------------------
# Frontend
# ------------------------------------------------------------------
# Vazio = chamadas relativas /api resolvidas pelo Caddy (recomendado, sem CORS).
# Preencha só se a API estiver em outro domínio.
NEXT_PUBLIC_API_URL=

# ------------------------------------------------------------------
# Observabilidade
# ------------------------------------------------------------------
LOG_LEVEL=INFO
