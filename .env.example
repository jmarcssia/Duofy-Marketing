# DUOFY V1 - local development

APP_ENV=development
LOG_LEVEL=INFO

# Backend
API_HOST=0.0.0.0
API_PORT=8000
DATABASE_URL=postgresql+asyncpg://duofy:duofy@postgres:5432/duofy_v1
REDIS_URL=redis://redis:6379/0
# PLACEHOLDER - valido apenas com APP_ENV=development. Com APP_ENV!=development
# a API se RECUSA a subir com este default (app/settings.py). Gere um forte:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=change-me-local-dev-only-32-bytes-minimum
# C2: segredo dedicado para cifrar as chaves de provedor (Fernet). Se definido, rotacionar o
# JWT_SECRET_KEY NAO invalida as chaves ja cifradas. Se vazio, cai no JWT_SECRET_KEY (retrocompat).
# Em producao, defina um valor forte e SEPARADO do JWT (mesmo gerador do JWT).
# FERNET_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=720
BACKEND_CORS_ORIGINS=http://localhost:3000
ADMIN_EMAIL=admin@duofy.com.br
ADMIN_PASSWORD=admin123456
ADMIN_NAME=Admin Duofy

# Docker services
POSTGRES_DB=duofy_v1
POSTGRES_USER=duofy
POSTGRES_PASSWORD=duofy
POSTGRES_PORT=5433
REDIS_PORT=6379
WEB_PORT=3000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
